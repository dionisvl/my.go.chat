# Production profile. Set strong secrets and lock down origins before deploying.

APP_ENV=prod
APP_EXTERNAL_PORT=8011
WELCOME_MESSAGE=""
WELCOME_TIMEOUT=0
PROFANITIES=""
CHAT_HISTORY_LIMIT=50
# REQUIRED in prod: comma-separated list of allowed websocket origins.
CORS_TRUSTED_ORIGINS=https://chat.example.com

DB_USER=chat
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=chat
DB_EXTERNAL_PORT=5433
