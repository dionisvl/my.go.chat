# Copy to .env and adjust. See compose.yml for how these map into the container.

# App
APP_ENV=dev
APP_EXTERNAL_PORT=8011
WELCOME_MESSAGE="Hello! Ask anything here."
WELCOME_TIMEOUT=0
PROFANITIES="badword1,badword2"
CHAT_HISTORY_LIMIT=50
# Comma-separated allowed websocket origins. Empty = allow all (dev only).
CORS_TRUSTED_ORIGINS=

# Database (PostgreSQL)
DB_USER=chat
DB_PASSWORD=chat
DB_NAME=chat
DB_EXTERNAL_PORT=5433
